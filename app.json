{
  "expo": {
    "name": "AuraCloset",
    "slug": "aura-closet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "auracloset",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.auracloset"
    },
    "android": {
      "package": "com.auracloset",
      "adaptiveIcon": {
        "backgroundColor": "#F5F3F0",
        "foregroundImage": "./assets/images/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AuraCloset to access your photos to add items to your wardrobe.",
          "cameraPermission": "Allow AuraCloset to use your camera to photograph wardrobe items."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
